<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mydin Training & Compliance Hub</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- React & ReactDOM 18 CDNs -->
    <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
    <!-- Babel CDN for browser-side JSX parsing -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <style>
        /* Smooth scrolling and premium styling overrides */
        html {
            scroll-behavior: smooth;
        }
    </style>
</head>
<body class="bg-slate-950 text-slate-100 font-sans">
    
    <!-- Mount point for the React Application -->
    <div id="root"></div>

    <script type="text/babel">
        // Destructuring React hooks for local script scope
        const { useState, useEffect } = React;

        // Inline Custom SVG Icons for maximum reliability and offline runtime compatibility
        const Icons = {
            Calculator: () => (
                <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 11h.01M12 14h.01M15 11h.01M12 7h.01M15 7h.01M15 14h.01M15 17h.01M9 11h.01M5 19V5a2 2 0 012-2h10a2 2 0 012 2v14a2 2 0 01-2 2H7a2 2 0 01-2-2z" />
                </svg>
            ),
            FileText: () => (
                <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
            ),
            Calendar: () => (
                <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
            ),
            Clock: () => (
                <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            ),
            CheckCircle: ({ className = "w-5 h-5" }) => (
                <svg className={className} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            ),
            AlertTriangle: ({ className = "w-5 h-5" }) => (
                <svg className={className} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
            ),
            Upload: () => (
                <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                </svg>
            ),
            Plus: () => (
                <svg className="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M12 4v16m8-8H4" />
                </svg>
            ),
            Trash: () => (
                <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
            )
        };

        function App() {
            const [activeTab, setActiveTab] = useState('calendarUpload');
            const [trainingDate, setTrainingDate] = useState('2026-07-15');
            const [activeCourseTitle, setActiveCourseTitle] = useState('Frontline Cashier Excellence');
            
            // Implementation countdown calculator (Target Date June 15, 2026)
            const [daysRemaining, setDaysRemaining] = useState(0);

            // Active Monthly Planning Horizon Tab
            const [planningMonth, setPlanningMonth] = useState('July 2026');

            // Default Master Training Calendar Schedule Database
            const [scheduledTrainings, setScheduledTrainings] = useState([
                { id: 1, title: 'Frontline Cashier Excellence', date: '2026-07-15', department: 'Retail Operations', trainer: 'MYRA Team A', monthGroup: 'July 2026' },
                { id: 2, title: 'POS Terminal Security Induction', date: '2026-07-02', department: 'IT Operations', trainer: 'Encik Roslan', monthGroup: 'July 2026' },
                { id: 3, title: 'Fresh Food Hygiene Standards', date: '2026-06-25', department: 'Fresh Market', trainer: 'Siti Aminah', monthGroup: 'June 2026' },
                { id: 4, title: 'Store Supervisor Onboarding Batch B', date: '2026-06-10', department: 'Management', trainer: 'MYRA Team B', monthGroup: 'June 2026' },
                { id: 5, title: 'Forklift Safety & Loading Bay Protocol', date: '2026-08-12', department: 'Warehouse & Logistics', trainer: 'Safety Officer Lim', monthGroup: 'August 2026' }
            ]);

            // Form input states for adding classes
            const [newTitle, setNewTitle] = useState('');
            const [newDate, setNewDate] = useState('');
            const [newDept, setNewDept] = useState('Retail Operations');
            const [newTrainer, setNewTrainer] = useState('');

            // Bulk File Upload/Paste States
            const [csvText, setCsvText] = useState('');
            const [bulkError, setBulkError] = useState('');
            const [uploadSuccess, setUploadSuccess] = useState(false);

            // Anchored System Reference date: May 25, 2026
            const systemDateStr = '2026-05-25';
            const systemDate = new Date(systemDateStr);

            useEffect(() => {
                const targetDate = new Date('2026-06-15');
                const timeDiff = targetDate.getTime() - systemDate.getTime();
                const days = Math.ceil(timeDiff / (1000 * 3600 * 24));
                setDaysRemaining(days);
            }, []);

            // Helper to dynamically calculate compliance safety indicators
            const evaluateStatus = (dateString) => {
                const tDate = new Date(dateString);
                const dayDiff = Math.ceil((tDate.getTime() - systemDate.getTime()) / (1000 * 3600 * 24));
                
                if (dayDiff < 14) {
                    return 'Non-Compliant'; // Direct failure of HRDCorp 14-day clearance
                } else if (dayDiff >= 14 && dayDiff <= 20) {
                    return 'Critical Risk'; // Tight warning buffer
                } else {
                    return 'Fully Compliant'; // Safe operating window (21+ days lead time)
                }
            };

            // Map dataset values with real-time audit statuses
            const activeTrainings = scheduledTrainings.map(t => ({
                ...t,
                status: evaluateStatus(t.date)
            }));

            // Group selector parser based on date
            const getMonthGroupFromDate = (dateString) => {
                const dateObj = new Date(dateString);
                const months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
                return `${months[dateObj.getMonth()]} ${dateObj.getFullYear()}`;
            };

            // Add individual manual class handler
            const handleAddTraining = (e) => {
                e.preventDefault();
                if (!newTitle || !newDate || !newTrainer) return;

                const group = getMonthGroupFromDate(newDate);

                const newObj = {
                    id: Date.now(),
                    title: newTitle,
                    date: newDate,
                    department: newDept,
                    trainer: newTrainer,
                    monthGroup: group
                };

                setScheduledTrainings([newObj, ...scheduledTrainings]);
                setPlanningMonth(group); // Focus on active month
                setNewTitle('');
                setNewDate('');
                setNewTrainer('');
            };

            // Remove a course from array
            const handleDeleteTraining = (id) => {
                setScheduledTrainings(scheduledTrainings.filter(t => t.id !== id));
            };

            // CSV paste parser
            const handleBulkImport = () => {
                if (!csvText.trim()) {
                    setBulkError('Please paste some training details first.');
                    return;
                }
                
                const lines = csvText.split('\n');
                const parsedTrainings = [];
                let formatIssue = false;

                lines.forEach((line, idx) => {
                    if (!line.trim()) return;
                    const parts = line.split(',');
                    if (parts.length < 4) {
                        formatIssue = true;
                        return;
                    }

                    const [title, dateStr, dept, trainer] = parts.map(p => p.trim());
                    const dateRegex = /^\d{4}-\d{2}-\d{2}$/;
                    if (!dateRegex.test(dateStr)) {
                        formatIssue = true;
                        return;
                    }

                    parsedTrainings.push({
                        id: Date.now() + idx,
                        title,
                        date: dateStr,
                        department: dept || 'Retail Operations',
                        trainer: trainer || 'MYRA Team',
                        monthGroup: getMonthGroupFromDate(dateStr)
                    });
                });

                if (formatIssue) {
                    setBulkError('Format mismatch. Ensure fields are split by commas, and date is structured as YYYY-MM-DD.');
                } else {
                    setScheduledTrainings([...parsedTrainings, ...scheduledTrainings]);
                    setCsvText('');
                    setBulkError('');
                    setUploadSuccess(true);
                    setTimeout(() => setUploadSuccess(false), 3000);
                    if (parsedTrainings.length > 0) {
                        setPlanningMonth(parsedTrainings[0].monthGroup);
                    }
                }
            };

            // Timeline Calculator Engine
            const calculateTimeline = (tDate) => {
                if (!tDate) return null;
                const dateObj = new Date(tDate);
                
                const nominationDate = new Date(dateObj);
                nominationDate.setDate(dateObj.getDate() - 21);

                const signOffDate = new Date(dateObj);
                signOffDate.setDate(dateObj.getDate() - 16);

                const submitDate = new Date(dateObj);
                submitDate.setDate(dateObj.getDate() - 14);

                const calendarMonthIndex = dateObj.getMonth() - 1;
                const months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
                const prevMonthName = months[calendarMonthIndex < 0 ? 11 : calendarMonthIndex];

                return {
                    prevMonthName,
                    nomination: nominationDate.toLocaleDateString('en-MY', { day: 'numeric', month: 'long', year: 'numeric' }),
                    signoff: signOffDate.toLocaleDateString('en-MY', { day: 'numeric', month: 'long', year: 'numeric' }),
                    submission: submitDate.toLocaleDateString('en-MY', { day: 'numeric', month: 'long', year: 'numeric' }),
                    training: dateObj.toLocaleDateString('en-MY', { day: 'numeric', month: 'long', year: 'numeric' })
                };
            };

            const schedule = calculateTimeline(trainingDate);

            // Select item from grid, auto-route view to calculator tab
            const selectTrainingForTimeline = (course) => {
                setTrainingDate(course.date);
                setActiveCourseTitle(course.title);
                setActiveTab('timeline');
            };

            const filteredTrainings = activeTrainings.filter(t => t.monthGroup === planningMonth);

            return (
                <div className="min-h-screen bg-slate-950 text-slate-100 font-sans selection:bg-red-600 selection:text-white">
                    {/* Top Banner & Corporate Branding */}
                    <header className="border-b border-slate-800 bg-slate-900 sticky top-0 z-50 shadow-md">
                        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3.5 flex flex-col md:flex-row items-center justify-between gap-4">
                            
                            {/* Mydin Logo container with fallback image triggers */}
                            <div className="flex items-center space-x-3.5">
                                <div className="bg-white p-1 rounded border border-slate-200 shadow flex items-center justify-center max-h-[44px]">
                                    <img 
                                        src="MYDIN LOGO (CI)2023-FAOL_Fit-03.png" 
                                        alt="Mydin Logo" 
                                        className="h-8.5 w-auto object-contain"
                                        onError={(e) => { 
                                            e.target.onerror = null; 
                                            e.target.src = "Logo_of_Mydin.png";
                                            e.target.addEventListener('error', (err) => {
                                                err.target.onerror = null;
                                                err.target.src = "https://placehold.co/150x50/1e3a8a/ffffff?text=MYDIN";
                                            });
                                        }} 
                                    />
                                </div>
                                <div className="h-8 w-px bg-slate-700 hidden md:block" />
                                <div>
                                    <h1 className="text-base sm:text-lg font-bold tracking-tight text-white flex items-center gap-2">
                                        Training & Compliance Hub 
                                        <span className="text-[10px] bg-red-500/10 text-red-400 border border-red-500/20 px-2 py-0.5 rounded font-medium">
                                            Internal Operations
                                        </span>
                                    </h1>
                                    <p className="text-[11px] text-slate-400">System Reference Date: May 25, 2026</p>
                                </div>
                            </div>
                            
                            <div className="flex items-center space-x-4 bg-slate-950/60 p-2.5 rounded-lg border border-slate-800">
                                <div className="text-right">
                                    <span className="text-[10px] text-slate-500 block uppercase tracking-wider font-semibold font-mono">HRD Corp Circular Implementation</span>
                                    <span className="text-sm font-bold text-amber-400 flex items-center justify-end gap-1.5 font-mono">
                                        <Icons.Clock />
                                        {daysRemaining} Days Until June 15 Release
                                    </span>
                                </div>
                            </div>
                        </div>
                    </header>

                    {/* Main Container */}
                    <main className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
                        
                        {/* Navigation Tabs */}
                        <div className="flex border-b border-slate-800 gap-1 mb-8">
                            <button
                                onClick={() => setActiveTab('calendarUpload')}
                                className={`flex items-center space-x-2 px-5 py-3 border-b-2 text-sm font-semibold transition ${
                                    activeTab === 'calendarUpload'
                                        ? 'border-red-500 text-white bg-slate-900/60'
                                        : 'border-transparent text-slate-400 hover:text-slate-200 hover:bg-slate-900/20'
                                }`}
                            >
                                <Icons.Calendar />
                                <span>Advance Calendar Panel</span>
                            </button>

                            <button
                                onClick={() => setActiveTab('timeline')}
                                className={`flex items-center space-x-2 px-5 py-3 border-b-2 text-sm font-semibold transition ${
                                    activeTab === 'timeline'
                                        ? 'border-red-500 text-white bg-slate-900/60'
                                        : 'border-transparent text-slate-400 hover:text-slate-200 hover:bg-slate-900/20'
                                }`}
                            >
                                <Icons.Calculator />
                                <span>Interactive Timeline Planner</span>
                            </button>
                            
                            <button
                                onClick={() => setActiveTab('circular')}
                                className={`flex items-center space-x-2 px-5 py-3 border-b-2 text-sm font-semibold transition ${
                                    activeTab === 'circular'
                                        ? 'border-red-500 text-white bg-slate-900/60'
                                        : 'border-transparent text-slate-400 hover:text-slate-200 hover:bg-slate-900/20'
                                }`}
                            >
                                <Icons.FileText />
                                <span>Circular No. 2/2026 Explorer</span>
                            </button>
                        </div>

                        {/* TAB 1: ADVANCE TRAINING CALENDAR UPLOAD PANEL */}
                        {activeTab === 'calendarUpload' && (
                            <div className="space-y-6">
                                
                                {/* Header Area */}
                                <div className="bg-slate-900 border border-slate-800 rounded-xl p-6 flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
                                    <div>
                                        <h2 className="text-xl font-bold text-white mb-1.5 flex items-center gap-2">
                                            <Icons.Calendar /> Advance Training Calendar Planner
                                        </h2>
                                        <p className="text-xs text-slate-400 max-w-2xl leading-relaxed">
                                            Trainers are strictly mandated to lock and submit training schedules **one month prior** to block execution. Use this dashboard to queue courses, batch upload lists, and run automated compliance rule audits.
                                        </p>
                                    </div>
                                    <div className="bg-slate-950 px-4 py-2.5 rounded-lg border border-slate-800 text-center">
                                        <span className="text-[10px] text-slate-500 block uppercase font-bold">Planned Database Pool</span>
                                        <span className="text-lg font-black text-white">{scheduledTrainings.length} Active Classes</span>
                                    </div>
                                </div>

                                {/* Notification Alert */}
                                {uploadSuccess && (
                                    <div className="bg-emerald-500/10 border border-emerald-500/20 p-4 rounded-xl flex items-center space-x-2 text-emerald-400 text-sm">
                                        <Icons.CheckCircle className="text-emerald-400 shrink-0" />
                                        <span>Batch calendar upload was successfully processed and merged into the active planner database.</span>
                                    </div>
                                )}

                                {/* Grid Layout split */}
                                <div className="grid grid-cols-1 lg:grid-cols-12 gap-6">
                                    
                                    {/* Left Side: Adding controls */}
                                    <div className="lg:col-span-4 space-y-6">
                                        
                                        {/* Panel 1: Individual Course Form */}
                                        <div className="bg-slate-900 border border-slate-800 rounded-xl p-5 space-y-4">
                                            <h3 className="text-xs font-bold text-white uppercase tracking-wider flex items-center gap-1.5 border-b border-slate-800 pb-3">
                                                <Icons.Plus /> Queue New Class
                                            </h3>
                                            
                                            <form onSubmit={handleAddTraining} className="space-y-3.5">
                                                <div>
                                                    <label className="block text-[11px] font-semibold text-slate-400 uppercase tracking-wider mb-1">Course Title</label>
                                                    <input 
                                                        type="text" 
                                                        required
                                                        placeholder="e.g. Cashier Induction Batch A"
                                                        value={newTitle}
                                                        onChange={(e) => setNewTitle(e.target.value)}
                                                        className="w-full bg-slate-950 border border-slate-800 rounded-lg px-3 py-2 text-xs text-white focus:outline-none focus:border-red-500"
                                                    />
                                                </div>

                                                <div>
                                                    <label className="block text-[11px] font-semibold text-slate-400 uppercase tracking-wider mb-1">Commencement Date</label>
                                                    <input 
                                                        type="date" 
                                                        required
                                                        value={newDate}
                                                        onChange={(e) => setNewDate(e.target.value)}
                                                        className="w-full bg-slate-950 border border-slate-800 rounded-lg px-3 py-2 text-xs text-white font-bold focus:outline-none focus:border-red-500"
                                                    />
                                                </div>

                                                <div>
                                                    <label className="block text-[11px] font-semibold text-slate-400 uppercase tracking-wider mb-1">Department Sector</label>
                                                    <select 
                                                        value={newDept}
                                                        onChange={(e) => setNewDept(e.target.value)}
                                                        className="w-full bg-slate-950 border border-slate-800 rounded-lg px-3 py-2 text-xs text-slate-300 focus:outline-none focus:border-red-500"
                                                    >
                                                        <option value="Retail Operations">Retail Operations</option>
                                                        <option value="Fresh Market">Fresh Market</option>
                                                        <option value="Management">Management</option>
                                                        <option value="IT Operations">IT Operations</option>
                                                        <option value="Warehouse & Logistics">Warehouse & Logistics</option>
                                                    </select>
                                                </div>

                                                <div>
                                                    <label className="block text-[11px] font-semibold text-slate-400 uppercase tracking-wider mb-1">Lead Instructor/Trainer</label>
                                                    <input 
                                                        type="text" 
                                                        required
                                                        placeholder="e.g. Siti Aminah / MYRA Team"
                                                        value={newTrainer}
                                                        onChange={(e) => setNewTrainer(e.target.value)}
                                                        className="w-full bg-slate-950 border border-slate-800 rounded-lg px-3 py-2 text-xs text-white focus:outline-none focus:border-red-500"
                                                    />
                                                </div>

                                                <button 
                                                    type="submit"
                                                    className="w-full bg-red-600 hover:bg-red-500 text-white font-bold py-2.5 rounded text-xs transition mt-2 flex items-center justify-center shadow"
                                                >
                                                    <Icons.Plus /> Queue Class to Database
                                                </button>
                                            </form>
                                        </div>

                                        {/* Panel 2: Bulk CSV pasted imports */}
                                        <div className="bg-slate-900 border border-slate-800 rounded-xl p-5 space-y-4">
                                            <h3 className="text-xs font-bold text-white uppercase tracking-wider flex items-center gap-1.5 border-b border-slate-800 pb-3">
                                                <Icons.Upload /> Bulk Calendar Importer
                                            </h3>
                                            <p className="text-[11px] text-slate-400 leading-normal">
                                                Format: `Course Title, YYYY-MM-DD, Department, Trainer` (One record per row)
                                            </p>

                                            <div className="space-y-3">
                                                <textarea 
                                                    rows="4"
                                                    value={csvText}
                                                    onChange={(e) => setCsvText(e.target.value)}
                                                    placeholder="Halal Cutting Practice, 2026-07-19, Fresh Market, Chef Ahmad&#10;Logistics Crane Operator Certification, 2026-07-26, Logistics, Safety Unit"
                                                    className="w-full bg-slate-950 border border-slate-800 rounded-lg p-2.5 text-[11px] text-slate-300 font-mono focus:outline-none focus:border-red-500 leading-relaxed"
                                                />

                                                {bulkError && (
                                                    <span className="text-[11px] text-red-400 font-bold block">{bulkError}</span>
                                                )}

                                                <button 
                                                    onClick={handleBulkImport}
                                                    className="w-full border border-slate-700 hover:bg-slate-800 text-slate-200 font-bold py-2 rounded text-xs transition"
                                                >
                                                    Process & Parse Calendar
                                                </button>
                                            </div>
                                        </div>

                                    </div>

                                    {/* Right Side: Active Master Schedule Board */}
                                    <div className="lg:col-span-8 bg-slate-900 border border-slate-800 rounded-xl p-5 space-y-5">
                                        
                                        {/* Month selectors */}
                                        <div className="flex flex-col sm:flex-row sm:items-center justify-between gap-3 border-b border-slate-800 pb-3.5">
                                            <div className="flex items-center space-x-2">
                                                <span className="text-xs font-bold text-slate-400 uppercase tracking-wider">Select Planning Month:</span>
                                            </div>
                                            <div className="flex flex-wrap gap-1.5">
                                                {['June 2026', 'July 2026', 'August 2026'].map((m) => (
                                                    <button
                                                        key={m}
                                                        onClick={() => setPlanningMonth(m)}
                                                        className={`px-3 py-1.5 rounded-lg text-xs font-bold border transition ${
                                                            planningMonth === m
                                                                ? 'bg-red-600 border-red-500 text-white shadow'
                                                                : 'bg-slate-950 border-slate-800 text-slate-400 hover:text-slate-200'
                                                        }`}
                                                    >
                                                        {m}
                                                    </button>
                                                ))}
                                            </div>
                                        </div>

                                        {/* Internal calendar submission countdown indicator context */}
                                        <div className="bg-slate-950 p-4 rounded-xl border border-slate-850 flex items-center justify-between gap-4 flex-wrap">
                                            <div className="space-y-0.5">
                                                <span className="text-[10px] uppercase font-bold text-slate-500 block tracking-wider">Internal Calendar Upload Deadline</span>
                                                <span className="text-xs font-bold text-white block">
                                                    {planningMonth === 'June 2026' ? 'First Week of May 2026 (Passed)' : planningMonth === 'July 2026' ? 'First Week of June 2026 (Targeting)' : 'First Week of July 2026'}
                                                </span>
                                            </div>
                                            <div className="text-right">
                                                <span className="text-[10px] uppercase font-bold text-slate-500 block tracking-wider">Operational Status</span>
                                                {filteredTrainings.some(t => t.status === 'Non-Compliant') ? (
                                                    <span className="text-xs font-bold text-red-400 bg-red-500/10 px-2.5 py-0.5 rounded border border-red-500/20 uppercase tracking-wider">Conflict: Blocked Dates</span>
                                                ) : filteredTrainings.some(t => t.status === 'Critical Risk') ? (
                                                    <span className="text-xs font-bold text-amber-400 bg-amber-400/10 px-2.5 py-0.5 rounded border border-amber-500/20 uppercase tracking-wider">Attention: Tight Buffer</span>
                                                ) : (
                                                    <span className="text-xs font-bold text-emerald-400 bg-emerald-400/10 px-2.5 py-0.5 rounded border border-emerald-500/20 uppercase tracking-wider">100% Compliant</span>
                                                )}
                                            </div>
                                        </div>

                                        {/* Table details listing */}
                                        <div className="overflow-x-auto">
                                            <table className="w-full text-left border-collapse text-xs">
                                                <thead>
                                                    <tr className="bg-slate-950 border-b border-slate-850 text-slate-400">
                                                        <th className="p-3 font-semibold uppercase tracking-wider w-5/12">Course Details</th>
                                                        <th className="p-3 font-semibold uppercase tracking-wider w-2/12">Department</th>
                                                        <th className="p-3 font-semibold uppercase tracking-wider w-2/12">Proposed Date</th>
                                                        <th className="p-3 font-semibold uppercase tracking-wider text-center w-2/12">Audit Result</th>
                                                        <th className="p-3 font-semibold uppercase tracking-wider text-right w-1/12">Actions</th>
                                                    </tr>
                                                </thead>
                                                <tbody className="divide-y divide-slate-800/40">
                                                    {filteredTrainings.map((t) => (
                                                        <tr key={t.id} className="hover:bg-slate-950/40 transition">
                                                            <td className="p-3">
                                                                <button 
                                                                    onClick={() => selectTrainingForTimeline(t)}
                                                                    className="font-bold text-white hover:text-red-400 text-left block"
                                                                >
                                                                    {t.title}
                                                                </button>
                                                                <span className="text-[10px] text-slate-500">Instructor: {t.trainer} • ID: #{t.id.toString().slice(-4)}</span>
                                                            </td>
                                                            <td className="p-3 text-slate-300">{t.department}</td>
                                                            <td className="p-3 font-mono text-slate-200">{t.date}</td>
                                                            <td className="p-3 text-center">
                                                                {t.status === 'Fully Compliant' ? (
                                                                    <span className="bg-emerald-500/15 text-emerald-400 border border-emerald-500/30 px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider">
                                                                        Compliant
                                                                    </span>
                                                                ) : t.status === 'Critical Risk' ? (
                                                                    <span className="bg-amber-500/15 text-amber-400 border border-amber-500/30 px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider">
                                                                        Warning: Tight
                                                                    </span>
                                                                ) : (
                                                                    <span className="bg-red-500/15 text-red-400 border border-red-500/30 px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider">
                                                                        Non-Compliant
                                                                    </span>
                                                                )}
                                                            </td>
                                                            <td className="p-3 text-right space-x-1">
                                                                <button 
                                                                    onClick={() => selectTrainingForTimeline(t)}
                                                                    className="text-red-400 hover:text-red-300 font-bold px-2 py-1 hover:bg-slate-950 rounded transition inline-block"
                                                                >
                                                                    Timeline
                                                                </button>
                                                                <button 
                                                                    onClick={() => handleDeleteTraining(t.id)}
                                                                    className="text-slate-500 hover:text-red-400 p-1 rounded inline-block transition"
                                                                    title="Delete Course"
                                                                >
                                                                    <Icons.Trash />
                                                                </button>
                                                            </td>
                                                        </tr>
                                                    ))}
                                                </tbody>
                                            </table>
                                        </div>

                                        {filteredTrainings.length === 0 && (
                                            <div className="text-center py-10 text-slate-500">
                                                No classes have been mapped for {planningMonth} yet. Use the sidebar panel to queue courses.
                                            </div>
                                        )}
                                        
                                    </div>

                                </div>

                            </div>
                        )}

                        {/* TAB 2: INTERACTIVE TIMELINE PLANNER */}
                        {activeTab === 'timeline' && (
                            <div className="space-y-6">
                                <div className="bg-slate-900 border border-slate-800 rounded-xl p-6">
                                    <h2 className="text-xl font-bold text-white mb-2 flex items-center gap-2">
                                        <Icons.Calculator /> Internal Target Deadline Calculator
                                    </h2>
                                    <p className="text-sm text-slate-400 mb-6">
                                        Under HRD Corp Circular No. 2/2026, training parameters are locked upon submission and grants must be approved <span className="text-red-400 font-semibold">14 calendar days prior</span> to launching. Select or enter any training program date to trace critical compliance buffers.
                                    </p>

                                    <div className="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-3xl">
                                        <div className="bg-slate-950 border border-slate-800 p-4 rounded-lg">
                                            <label className="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Selected Course Reference</label>
                                            <input 
                                                type="text" 
                                                value={activeCourseTitle}
                                                onChange={(e) => setActiveCourseTitle(e.target.value)}
                                                className="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 text-white font-semibold focus:outline-none focus:border-red-500 text-sm"
                                            />
                                        </div>
                                        
                                        <div className="bg-slate-950 border border-slate-800 p-4 rounded-lg">
                                            <label className="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Proposed Training Commencement Date</label>
                                            <input 
                                                type="date" 
                                                value={trainingDate} 
                                                onChange={(e) => setTrainingDate(e.target.value)}
                                                className="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2 text-white font-bold focus:outline-none focus:border-red-500 text-sm"
                                            />
                                        </div>
                                    </div>
                                </div>

                                {/* Generated Timelines Visual Board */}
                                <div className="grid grid-cols-1 lg:grid-cols-4 gap-4">
                                    
                                    {/* Step 1 */}
                                    <div className="bg-slate-900 border border-slate-800 rounded-xl p-5 relative overflow-hidden flex flex-col justify-between">
                                        <div className="absolute top-0 right-0 bg-blue-500/10 text-blue-400 text-xs font-bold px-3 py-1 rounded-bl">Step 1</div>
                                        <div>
                                            <span className="text-xs uppercase font-semibold text-slate-500 tracking-wider">Phase 1: Calendar Upload</span>
                                            <h3 className="text-base font-bold text-blue-400 mt-2 mb-1">First Week of {schedule?.prevMonthName || 'Prior Month'}</h3>
                                            <p className="text-xs text-slate-400 leading-relaxed">
                                                All MYRA trainers must lock and upload upcoming month programs to the corporate master spreadsheet.
                                            </p>
                                        </div>
                                        <div className="mt-4 pt-3 border-t border-slate-800 flex items-center text-xs text-slate-500">
                                            <Icons.Clock /> <span className="ml-1.5">Action: Trainer submission</span>
                                        </div>
                                    </div>

                                    {/* Step 2 */}
                                    <div className="bg-slate-900 border border-slate-800 rounded-xl p-5 relative overflow-hidden flex flex-col justify-between">
                                        <div className="absolute top-0 right-0 bg-amber-500/10 text-amber-400 text-xs font-bold px-3 py-1 rounded-bl">Step 2</div>
                                        <div>
                                            <span className="text-xs uppercase font-semibold text-slate-500 tracking-wider">Phase 2: Nomination Window</span>
                                            <h3 className="text-base font-bold text-amber-400 mt-2 mb-1">{schedule?.nomination}</h3>
                                            <p className="text-xs text-slate-400 leading-relaxed">
                                                Nominations officially open. All profiles are selected via core MYRA databases or added by Branch Managers.
                                            </p>
                                        </div>
                                        <div className="mt-4 pt-3 border-t border-slate-800 flex items-center text-xs text-slate-500">
                                            <Icons.Clock /> <span className="ml-1.5">21 Days Prior to Training</span>
                                        </div>
                                    </div>

                                    {/* Step 3 */}
                                    <div className="bg-slate-900 border border-slate-800 rounded-xl p-5 relative overflow-hidden flex flex-col justify-between">
                                        <div className="absolute top-0 right-0 bg-emerald-500/10 text-emerald-400 text-xs font-bold px-3 py-1 rounded-bl">Step 3</div>
                                        <div>
                                            <span className="text-xs uppercase font-semibold text-slate-500 tracking-wider">Phase 3: Digital Sign-off</span>
                                            <h3 className="text-base font-bold text-emerald-400 mt-2 mb-1">{schedule?.signoff}</h3>
                                            <p className="text-xs text-slate-400 leading-relaxed">
                                                Trainees and direct managers complete the 48-hour digital confirmation process to ensure attendance lock.
                                            </p>
                                        </div>
                                        <div className="mt-4 pt-3 border-t border-slate-800 flex items-center text-xs text-slate-500">
                                            <Icons.Clock /> <span className="ml-1.5">16 Days Prior to Training</span>
                                        </div>
                                    </div>

                                    {/* Step 4 */}
                                    <div className="bg-slate-900 border border-slate-800 rounded-xl p-5 relative overflow-hidden flex flex-col justify-between border-l-4 border-l-red-500">
                                        <div className="absolute top-0 right-0 bg-red-500/10 text-red-400 text-xs font-bold px-3 py-1 rounded-bl">Step 4</div>
                                        <div>
                                            <span className="text-xs uppercase font-semibold text-red-500 tracking-wider font-bold">Phase 4: Submit & Lock</span>
                                            <h3 className="text-base font-bold text-red-400 mt-2 mb-1">{schedule?.submission}</h3>
                                            <p className="text-xs text-slate-400 leading-relaxed">
                                                All grant proposal documents must be uploaded into the HRD Corp Portal. This leaves the required 14-day cushion.
                                            </p>
                                        </div>
                                        <div className="mt-4 pt-3 border-t border-slate-800 flex items-center text-xs text-slate-500">
                                            <Icons.Clock /> <span className="ml-1.5 font-semibold text-red-500">14 Days Prior to Training</span>
                                        </div>
                                    </div>

                                </div>

                                {/* Target Execution Card */}
                                <div className="bg-gradient-to-r from-red-950/40 via-slate-900 to-slate-900 border border-red-500/30 p-6 rounded-xl flex flex-col md:flex-row items-center justify-between gap-6">
                                    <div>
                                        <span className="text-xs text-red-400 font-bold tracking-widest uppercase">Target execution for: "{activeCourseTitle}"</span>
                                        <h4 className="text-2xl font-black text-white mt-1">{schedule?.training}</h4>
                                        <p className="text-sm text-slate-400 mt-1 max-w-xl">
                                            By adhering strictly to this timeline, Mydin protects its levy funds, completely avoids post-approval modifications, and ensures zero operational disruptions on the store floor.
                                        </p>
                                    </div>
                                    <div className="bg-slate-800 text-white font-bold px-5 py-3 rounded-lg flex items-center space-x-2 border border-slate-700 hover:bg-slate-700 transition cursor-pointer" onClick={() => setActiveTab('calendarUpload')}>
                                        <span>Manage Upcoming Calendar</span>
                                        <Icons.Calendar />
                                    </div>
                                </div>

                                {/* Warning Message Box */}
                                <div className="bg-amber-950/30 border border-amber-500/20 rounded-xl p-5 flex items-start space-x-3.5">
                                    <Icons.AlertTriangle className="text-amber-500 w-6 h-6 shrink-0 mt-0.5" />
                                    <div>
                                        <h4 className="text-sm font-bold text-amber-400">Strict Attendance Notice for Line Managers</h4>
                                        <p className="text-xs text-slate-400 mt-1 leading-relaxed">
                                            Under the revised policy, modifications cannot be made after a grant is approved. No-shows directly trigger rejected claims. If a core trainee falls sick or gets reassigned, alternate standby trainees must be swapped in on the claims portal at module completion. Standby pools must be maintained for all courses.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        )}

                        {/* TAB 3: CIRCULAR NO. 2/2026 EXPLORER */}
                        {activeTab === 'circular' && (
                            <div className="space-y-6">
                                <div className="bg-slate-900 border border-slate-800 rounded-xl p-6">
                                    <h2 className="text-xl font-bold text-white mb-2">HRD Corp Circular vs. Mydin Internal Measures</h2>
                                    <p className="text-sm text-slate-400">
                                        A granular assessment of how national policy revisions are being transformed into robust, compliant internal Mydin training habits.
                                    </p>
                                </div>

                                <div className="overflow-x-auto border border-slate-800 rounded-xl bg-slate-900">
                                    <table className="w-full text-left border-collapse">
                                        <thead>
                                            <tr className="bg-slate-950 border-b border-slate-800 font-mono text-slate-400">
                                                <th className="p-4 text-xs font-bold uppercase tracking-wider w-1/4">Operational Area</th>
                                                <th className="p-4 text-xs font-bold uppercase tracking-wider w-1/3">HRD Corp Circular Policy</th>
                                                <th className="p-4 text-xs font-bold uppercase tracking-wider w-1/3">Mydin Internal Compliance Plan</th>
                                            </tr>
                                        </thead>
                                        <tbody className="divide-y divide-slate-800/60">
                                            
                                            {/* Item 1 */}
                                            <tr className="hover:bg-slate-950/40 transition">
                                                <td className="p-4 align-top">
                                                    <span className="font-bold text-white block">14-Day Mandatory Approval Buffer</span>
                                                    <span className="text-[10px] text-red-400 bg-red-500/10 px-2 py-0.5 rounded font-semibold inline-block mt-1">Circular Item 1 & 3</span>
                                                </td>
                                                <td className="p-4 text-sm text-slate-400 align-top">
                                                    Employers must obtain complete, absolute grant approval at least <span className="text-slate-200 font-semibold">14 calendar days prior</span> to the training starting date. No late appeals or submissions will be registered.
                                                </td>
                                                <td className="p-4 text-sm text-slate-300 bg-slate-950/20 align-top">
                                                    <span className="font-bold text-amber-400 block mb-1">21-Day Cut-off Window</span>
                                                    All nomination forms must open 21 days out and close within 48 hours, locking the finalized list for upload on Day 15 to secure the 14-day clearance buffer.
                                                </td>
                                            </tr>

                                            {/* Item 2 */}
                                            <tr className="hover:bg-slate-950/40 transition">
                                                <td className="p-4 align-top">
                                                    <span className="font-bold text-white block">Abolishment of Modifications</span>
                                                    <span className="text-[10px] text-amber-400 bg-amber-500/10 px-2 py-0.5 rounded font-semibold inline-block mt-1">Circular Item 3 & 6</span>
                                                </td>
                                                <td className="p-4 text-sm text-slate-400 align-top">
                                                    No post-approval modifications to the scheduled dates, modules, or fees are permitted. Any structural change cancels the grant completely, necessitating a brand-new application.
                                                </td>
                                                <td className="p-4 text-sm text-slate-300 bg-slate-950/20 align-top">
                                                    <span className="font-bold text-emerald-400 block mb-1">Calendar Lock and Standby Pool</span>
                                                    Calendars are structurally locked 1 month prior. Standard standby "buffer pools" of 2-3 alternative trainees are formed to seamlessly absorb personal emergencies on training day.
                                                </td>
                                            </tr>

                                            {/* Item 3 */}
                                            <tr className="hover:bg-slate-950/40 transition">
                                                <td className="p-4 align-top">
                                                    <span className="font-bold text-white block">Slashed Query Windows</span>
                                                    <span className="text-[10px] text-purple-400 bg-purple-500/10 px-2 py-0.5 rounded font-semibold inline-block mt-1">Circular Item 3</span>
                                                </td>
                                                <td className="p-4 text-sm text-slate-400 align-top">
                                                    The query resolution window is reduced from 30 days to <span className="text-slate-200 font-semibold">5 calendar days</span>. Only a single (1) query is allowed per application before automatic rejection.
                                                </td>
                                                <td className="p-4 text-sm text-slate-300 bg-slate-950/20 align-top">
                                                    <span className="font-bold text-blue-400 block mb-1">Pre-Submission Validation Check</span>
                                                    Trainees and direct line managers must confirm details through our digital token 48 hours prior to final upload to ensure 100% data fidelity.
                                                </td>
                                            </tr>

                                            {/* Item 4 */}
                                            <tr className="hover:bg-slate-950/40 transition">
                                                <td className="p-4 align-top">
                                                    <span className="font-bold text-white block">Trainee Data Modifications</span>
                                                    <span className="text-[10px] text-teal-400 bg-teal-500/10 px-2 py-0.5 rounded font-semibold inline-block mt-1">Circular Item 6.2</span>
                                                </td>
                                                <td className="p-4 text-sm text-slate-400 align-top">
                                                    Changes to actual trainee details (names, IC numbers, or positions) are <span className="text-slate-200 font-semibold">only permitted during final claims submission</span>.
                                                </td>
                                                <td className="p-4 text-sm text-slate-300 bg-slate-950/20 align-top">
                                                    <span className="font-bold text-indigo-400 block mb-1">MYRA Database Automation</span>
                                                    Centralized matching selects candidate pipelines proactively. Final replacements are pushed smoothly on the final claims portal using our standby list.
                                                </td>
                                            </tr>

                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        )}

                    </main>

                    {/* Internal System Footer */}
                    <footer className="border-t border-slate-800 bg-slate-950 py-8 text-center mt-12">
                        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-slate-500 text-xs space-y-2">
                            <p>© 2026 Mydin Mohamed Holdings Berhad. Internal Corporate Use Only.</p>
                            <p>This web application acts as a compliance mapping buffer for HRD Corp policy transitions occurring on June 15, 2026.</p>
                        </div>
                    </footer>
                </div>
            );
        }

        // Mount the React Application securely to root element
        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
